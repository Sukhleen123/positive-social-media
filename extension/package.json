{
  "name": "psm-extension",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "cross-env BUILD_TARGET=background vite build && cross-env BUILD_TARGET=content vite build && cross-env BUILD_TARGET=popup vite build && node scripts/copy-assets.mjs",
    "build:watch": "npm run build -- --watch",
    "generate-icons": "node scripts/generate-icons.mjs",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@huggingface/transformers": "^3.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.290",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.1",
    "canvas": "^3.0.0",
    "cross-env": "^7.0.3",
    "typescript": "~5.6.3",
    "vite": "^6.0.0"
  }
}
